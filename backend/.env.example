# ⚠️ ARQUIVO DE EXEMPLO - NÃO ADICIONE CREDENCIAIS REAIS AQUI!
# Este arquivo mostra a estrutura necessária do .env
# Copie as credenciais reais para .env e .env.production apenas

# Modo de operação
NODE_ENV=production

# Banco de dados
DB_HOST=mysql.talmax-ti.com.br
DB_USER=seu_usuario_real
DB_PASSWORD=sua_senha_real
DB_NAME=seu_banco_real
PORT=5000

# Autenticação JWT
ADMIN_JWT_SECRET=sua_chave_jwt_super_secreta_aqui
ADMIN_JWT_EXPIRES_IN_SECONDS=28800

# CORS
CORS_ALLOWED_ORIGINS=https://seu_dominio.com,https://www.seu_dominio.com

# Cloudinary (nuvem - recomendado)
CLOUDINARY_CLOUD_NAME=seu_cloud_name_real
CLOUDINARY_API_KEY=sua_api_key_real
CLOUDINARY_API_SECRET=sua_api_secret_real
CLOUDINARY_FOLDER=talmax

# OPCIONAL: SFTP (fallback - ex: KingHost)
#SFTP_HOST=ftp.seu_host.com
#SFTP_USER=seu_usuario_sftp
#SFTP_PASSWORD=sua_senha_sftp
#SFTP_REMOTE_DIR=/caminho/remoto/img
#SFTP_PUBLIC_BASE_URL=https://seu_dominio.com/img

# OPCIONAL: Diretório local persistente
#UPLOAD_DIR=/var/data/site-talmax-img

